ACTION=$(call_gum choose "Theme & Font Selection" "Change Default Shell" --header "Termuxify Menu:")

if [ "$ACTION" = "Theme & Font Selection" ]; then
  CATEGORY=$(call_gum choose "Aethel" "Catppuccin" "Kanagawa" "Oxocarbon" "Gruvbox" "Everforest" "Nord" "Tokyo Night" --header "Select Theme Category:")
  
  case "$CATEGORY" in
    "Aethel") THEME_NAME=$(call_gum choose "Aethel Dark Hard" "Aethel Dark Medium" "Aethel Dark Soft" "Aethel Light Hard" "Aethel Light Medium" "Aethel Light Soft") ;;
    "Catppuccin") THEME_NAME=$(call_gum choose "Catppuccin Mocha" "Catppuccin Macchiato" "Catppuccin Frappe" "Catppuccin Latte") ;;
    "Kanagawa") THEME_NAME=$(call_gum choose "Kanagawa Wave" "Kanagawa Dragon" "Kanagawa Lotus") ;;
    "Oxocarbon") THEME_NAME=$(call_gum choose "Oxocarbon Dark" "Oxocarbon Light") ;;
    *) THEME_NAME="$CATEGORY" ;;
  esac

  FONT=$(call_gum choose "IBM Plex Mono" "Google Sans Code" "Ioskeley Mono" "Intel One Mono" "JetBrains Mono" "Monaspace Neon" --header "Select Termux Font:")

  mkdir -p ~/.termux
  printf "%b" "${THEMES[$THEME_NAME]}" > ~/.termux/colors.properties

  export SELECTED_FONT="$FONT"
  export REPO_URL_ENV="$REPO_URL"

  if call_gum spin --spinner dot --title "Downloading $FONT..." -- bash -c '
  TMP_FILE="${TMPDIR:-/data/local/tmp}/font.ttf.tmp"
  rm -f "$TMP_FILE"
  case "$SELECTED_FONT" in
    "IBM Plex Mono") FONT_FILE="BlexMonoNerdFont-Regular.ttf" ;;
    "Google Sans Code") FONT_FILE="GoogleSansCode-Regular.ttf" ;;
    "Ioskeley Mono") FONT_FILE="IoskeleyMonoNerdFont-Regular.ttf" ;;
    "Intel One Mono") FONT_FILE="IntelOneMono-Regular.ttf" ;;
    "JetBrains Mono") FONT_FILE="JetBrainsMono-Regular.ttf" ;;
    "Monaspace Neon") FONT_FILE="MonaspaceNeon-Regular.ttf" ;;
  esac
  wget -qO "$TMP_FILE" "$REPO_URL_ENV/fonts/$FONT_FILE"
  if [ -f "$TMP_FILE" ] && [ $(wc -c < "$TMP_FILE") -gt 10000 ]; then
    mv "$TMP_FILE" ~/.termux/font.ttf
    exit 0
  else
    rm -f "$TMP_FILE"
    exit 1
  fi
  '; then
    termux-reload-settings
    clear
    command -v nerdfetch >/dev/null 2>&1 && nerdfetch || true
    call_gum format "### [+] Termuxify: Theme and Font applied successfully!"
  else
    clear
    call_gum format "### [-] Error: Font download failed. Check your connection or GitHub access."
  fi

elif [ "$ACTION" = "Change Default Shell" ]; then
  NEW_SHELL=$(call_gum choose "Nushell" "Bash" "Zsh" "Fish" --header "Select Default Shell:")

  case "$NEW_SHELL" in
    "Nushell")
      call_gum spin --spinner dot --title "Installing Nushell..." -- pkg install -y nushell
      mkdir -p "$HOME/.config/nushell"
      cat << 'EOF' > "$HOME/.config/nushell/termuxify_env.nu"
$env.STARSHIP_SHELL = "nu"
$env.STARSHIP_SESSION_KEY = (random chars -l 16)
$env.ATUIN_SESSION = (atuin uuid)
EOF
      cat << 'EOF' > "$HOME/.config/nushell/termuxify_config.nu"
$env.config = { show_banner: false }
source ~/.config/nushell/starship.nu
nerdfetch
EOF
      starship init nu | sed 's/--right//g' > "$HOME/.config/nushell/starship.nu"
      
      if ! grep -q "termuxify_env.nu" "$HOME/.config/nushell/env.nu" 2>/dev/null; then
          echo "source ~/.config/nushell/termuxify_env.nu" >> "$HOME/.config/nushell/env.nu"
      fi
      if ! grep -q "termuxify_config.nu" "$HOME/.config/nushell/config.nu" 2>/dev/null; then
          echo "source ~/.config/nushell/termuxify_config.nu" >> "$HOME/.config/nushell/config.nu"
      fi
      update_config "$HOME/.bashrc" "if [[ $- == *i* ]] && [ -z \"$NU_VERSION\" ]; then exec nu; fi"
      chsh -s nu || true
      ;;
    "Bash")
      update_config "$HOME/.bashrc" "eval \"\$(starship init bash)\"\neval \"\$(atuin init bash)\"\nnerdfetch"
      chsh -s bash || true
      ;;
    "Zsh")
      call_gum spin --spinner dot --title "Installing Zsh..." -- pkg install -y zsh
      update_config "$HOME/.zshrc" "eval \"\$(starship init zsh)\"\neval \"\$(atuin init zsh)\"\nnerdfetch"
      update_config "$HOME/.bashrc" "if [[ $- == *i* ]] && [ -z \"$ZSH_VERSION\" ]; then exec zsh; fi"
      chsh -s zsh || true
      ;;
    "Fish")
      call_gum spin --spinner dot --title "Installing Fish..." -- pkg install -y fish
      mkdir -p "$HOME/.config/fish"
      update_config "$HOME/.config/fish/config.fish" "starship init fish | source\natuin init fish | source\nnerdfetch"
      update_config "$HOME/.bashrc" "if [[ $- == *i* ]] && [ -z \"$FISH_VERSION\" ]; then exec fish; fi"
      chsh -s fish || true
      ;;
  esac

  call_gum format "### [+] Default shell changed successfully to $NEW_SHELL!"
  call_gum format "### [!] Restart Termux to apply changes."
fi
