#!/usr/bin/env bash

set -e

REPO_URL="https://raw.githubusercontent.com/kerneldroid/termuxify/main"

for dep in wget unzip curl gum; do
    if ! command -v "$dep" >/dev/null 2>&1; then
        echo -e "\e[1;31m[-] Error: Required dependency '$dep' is not installed.\e[0m"
        echo -e "\e[1;33m[!] Please run setup.sh first.\e[0m"
        exit 1
    fi
done

call_gum() {
    command gum "$@"
}

update_config() {
    local file="$1"
    local content="$2"
    local start_marker="# --- TERMUXIFY START ---"
    local end_marker="# --- TERMUXIFY END ---"
    
    touch "$file"
    if grep -qF "$start_marker" "$file"; then
        local tmp_file
        tmp_file=$(mktemp)
        sed "/$start_marker/,/$end_marker/d" "$file" > "$tmp_file"
        cat "$tmp_file" > "$file"
        rm "$tmp_file"
    fi
    printf "\n%s\n%s\n%s\n" "$start_marker" "$content" "$end_marker" >> "$file"
}

