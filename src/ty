extract_material_colors() {
  local seed_hex=""
  local theme_style="TONAL_SPOT"
  local overlay_json=""

  overlay_json=$(settings get secure theme_customization_overlay_packages 2>/dev/null) || true

  if [ -z "$overlay_json" ] || [ "$overlay_json" = "null" ]; then
    overlay_json=$(content query --uri content://settings/secure --where "name='theme_customization_overlay_packages'" --projection value 2>/dev/null | grep -o 'value=.*' | cut -d= -f2-) || true
  fi

  if [ -n "$overlay_json" ] && [ "$overlay_json" != "null" ]; then
    seed_hex=$(echo "$overlay_json" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('android.theme.customization.system_palette', ''))
except:
    print('')
" 2>/dev/null) || true

    theme_style=$(echo "$overlay_json" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('android.theme.customization.theme_style', 'TONAL_SPOT'))
except:
    print('TONAL_SPOT')
" 2>/dev/null) || true
  fi

  if [ -n "$seed_hex" ] && [ "$seed_hex" != "null" ] && [ "$seed_hex" != "" ]; then
    THEMES["Material Color (System)"]=$(python3 -c "
import colorsys

def hex_to_rgb(h):
    h = h.lstrip('#')
    if len(h) == 8:
        h = h[2:]
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))

def rgb_to_hex(r, g, b):
    return '#{:02X}{:02X}{:02X}'.format(
        max(0, min(255, int(round(r)))),
        max(0, min(255, int(round(g)))),
        max(0, min(255, int(round(b))))
    )

def hsl_to_rgb(h, s, l):
    h = h % 360
    s = max(0, min(1, s))
    l = max(0, min(1, l))
    c = (1 - abs(2 * l - 1)) * s
    x = c * (1 - abs((h / 60) % 2 - 1))
    m = l - c / 2
    if h < 60:
        r, g, b = c, x, 0
    elif h < 120:
        r, g, b = x, c, 0
    elif h < 180:
        r, g, b = 0, c, x
    elif h < 240:
        r, g, b = 0, x, c
    elif h < 300:
        r, g, b = x, 0, c
    else:
        r, g, b = c, 0, x
    return ((r + m) * 255, (g + m) * 255, (b + m) * 255)

seed = '$seed_hex'
r, g, b = hex_to_rgb(seed)
h, l, s = colorsys.rgb_to_hls(r/255.0, g/255.0, b/255.0)
seed_hue = h * 360.0
seed_sat = s
seed_light = l

style = '$theme_style'

if style == 'VIBRANT':
    a1s, a2s, a3s = min(1.0, seed_sat * 1.3), min(1.0, seed_sat * 1.1), min(1.0, seed_sat * 1.2)
elif style == 'EXPRESSIVE':
    a1s, a2s, a3s = min(1.0, seed_sat * 1.2), min(1.0, seed_sat * 1.0), min(1.0, seed_sat * 1.4)
elif style == 'SPRITZ':
    a1s, a2s, a3s = seed_sat * 0.6, seed_sat * 0.5, seed_sat * 0.65
elif style == 'RAINBOW':
    a1s, a2s, a3s = min(1.0, seed_sat * 1.1), min(1.0, seed_sat * 1.0), min(1.0, seed_sat * 1.1)
elif style == 'FRUIT_SALAD':
    a1s, a2s, a3s = min(1.0, seed_sat * 1.3), min(1.0, seed_sat * 0.9), min(1.0, seed_sat * 1.2)
else:
    a1s, a2s, a3s = min(1.0, seed_sat * 1.0), min(1.0, seed_sat * 0.8), min(1.0, seed_sat * 0.9)

def tone(hue, sat, lightness):
    r, g, b = hsl_to_rgb(hue % 360, sat, lightness)
    return rgb_to_hex(r, g, b)

bg = tone(seed_hue, seed_sat * 0.15, 0.12)
fg = tone(seed_hue, seed_sat * 0.1, 0.9)
cursor_c = tone(seed_hue, a1s, 0.45)

lines = [
    f'background={bg}',
    f'foreground={fg}',
    f'cursor={cursor_c}',
    f'color0={tone(seed_hue, seed_sat * 0.2, 0.08)}',
    f'color1={tone(seed_hue, a1s, 0.5)}',
    f'color2={tone(seed_hue + 60, a3s, 0.4)}',
    f'color3={tone(seed_hue + 30, a2s, 0.5)}',
    f'color4={tone(seed_hue, a1s * 0.9, 0.6)}',
    f'color5={tone(seed_hue + 60, a3s * 0.9, 0.55)}',
    f'color6={tone(seed_hue + 30, a2s * 0.9, 0.5)}',
    f'color7={fg}',
    f'color8={tone(seed_hue, seed_sat * 0.15, 0.25)}',
    f'color9={tone(seed_hue, a1s, 0.65)}',
    f'color10={tone(seed_hue + 60, a3s, 0.55)}',
    f'color11={tone(seed_hue + 30, a2s, 0.6)}',
    f'color12={tone(seed_hue, a1s, 0.75)}',
    f'color13={tone(seed_hue + 60, a3s, 0.7)}',
    f'color14={tone(seed_hue + 30, a2s, 0.65)}',
    f'color15={tone(seed_hue, seed_sat * 0.05, 0.97)}',
]
print('\\\\n'.join(lines))
" 2>/dev/null) || true
  fi

  if [ -z "${THEMES["Material Color (System)"]}" ]; then
    THEMES["Material Color (System)"]="${THEMES["Material Color (Tonal Spot)"]}"
  fi
}

ACTION=$(call_gum choose "Theme & Font Selection" "Change Default Shell" --header "Termuxify Menu:")

if [ "$ACTION" = "Theme & Font Selection" ]; then
  CATEGORY=$(call_gum choose "Thundra" "Material Color" "Tokyo Night" "Everforest" "OkColors" "Aethel" "Catppuccin" "Kanagawa" "Oxocarbon" "Gruvbox" "Nord" --header "Select Theme Category:")
  
  case "$CATEGORY" in
    "Thundra") THEME_NAME=$(call_gum choose "Thundra Dark Hard" "Thundra Dark Normal" "Thundra Dark Soft" "Thundra Light Hard" "Thundra Light Normal" "Thundra Light Soft") ;;
    "Material Color")
      extract_material_colors
      THEME_NAME=$(call_gum choose "Material Color (System)" "Material Color (Tonal Spot)" "Material Color (Expressive)" "Material Color (Vibrant)" "Material Color (Spritz)" "Material Color (Rainbow)" "Material Color (Fruit Salad)" --header "Select Material Color Style:")
      ;;
    "Tokyo Night") THEME_NAME=$(call_gum choose "Tokyo Night" "Tokyo Night Storm" "Tokyo Night Moon" "Tokyo Night Day") ;;
    "Everforest") THEME_NAME=$(call_gum choose "Everforest Dark Hard" "Everforest Dark Medium" "Everforest Dark Soft" "Everforest Light Hard" "Everforest Light Medium" "Everforest Light Soft") ;;
    "OkColors") THEME_NAME=$(call_gum choose "OkColors Dark Smooth" "OkColors Dark Sharp" "OkColors Light Smooth" "OkColors Light Sharp") ;;
    "Aethel") THEME_NAME=$(call_gum choose "Aethel Dark Hard" "Aethel Dark Medium" "Aethel Dark Soft" "Aethel Light Hard" "Aethel Light Medium" "Aethel Light Soft") ;;
    "Catppuccin") THEME_NAME=$(call_gum choose "Catppuccin Mocha" "Catppuccin Macchiato" "Catppuccin Frappe" "Catppuccin Latte") ;;
    "Kanagawa") THEME_NAME=$(call_gum choose "Kanagawa Wave" "Kanagawa Dragon" "Kanagawa Lotus") ;;
    "Oxocarbon") THEME_NAME=$(call_gum choose "Oxocarbon Dark" "Oxocarbon Light") ;;
    "Gruvbox") THEME_NAME=$(call_gum choose "Gruvbox" "Gruvbox Material") ;;
    "Nord") THEME_NAME="Nord" ;;
    *) THEME_NAME="$CATEGORY" ;;
  esac

  FONT=$(call_gum choose "IBM Plex Mono" "Google Sans Code" "Ioskeley Mono" "Intel One Mono" "JetBrains Mono" "Monaspace Neon" --header "Select Termux Font:")

  mkdir -p ~/.termux
  printf "%b" "${THEMES[$THEME_NAME]}" > ~/.termux/colors.properties

  export SELECTED_FONT="$FONT"
  export REPO_URL_ENV="$REPO_URL"

  if call_gum spin --spinner dot --title "Downloading $FONT..." -- bash -c '
  TMP_FILE="${TMPDIR:-/data/local/tmp}/font.ttf.tmp"
  rm -f "$TMP_FILE"
  case "$SELECTED_FONT" in
    "IBM Plex Mono") FONT_FILE="BlexMonoNerdFont-Regular.ttf" ;;
    "Google Sans Code") FONT_FILE="GoogleSansCode-Regular.ttf" ;;
    "Ioskeley Mono") FONT_FILE="IoskeleyMonoNerdFont-Regular.ttf" ;;
    "Intel One Mono") FONT_FILE="IntelOneMono-Regular.ttf" ;;
    "JetBrains Mono") FONT_FILE="JetBrainsMono-Regular.ttf" ;;
    "Monaspace Neon") FONT_FILE="MonaspaceNeon-Regular.ttf" ;;
  esac
  wget -qO "$TMP_FILE" "$REPO_URL_ENV/fonts/$FONT_FILE"
  if [ -f "$TMP_FILE" ] && [ $(wc -c < "$TMP_FILE") -gt 10000 ]; then
    mv "$TMP_FILE" ~/.termux/font.ttf
    exit 0
  else
    rm -f "$TMP_FILE"
    exit 1
  fi
  '; then
    termux-reload-settings
    clear
    command -v nerdfetch >/dev/null 2>&1 && nerdfetch || true
    call_gum format "### [+] Termuxify: Theme and Font applied successfully!"
  else
    clear
    call_gum format "### [-] Error: Font download failed. Check your connection or GitHub access."
  fi

elif [ "$ACTION" = "Change Default Shell" ]; then
  NEW_SHELL=$(call_gum choose "Nushell" "Bash" "Zsh" "Fish" --header "Select Default Shell:")

  case "$NEW_SHELL" in
    "Nushell")
      call_gum spin --spinner dot --title "Installing Nushell..." -- pkg install -y nushell
      mkdir -p "$HOME/.config/nushell"
      cat << 'EOF' > "$HOME/.config/nushell/termuxify_env.nu"
$env.STARSHIP_SHELL = "nu"
$env.STARSHIP_SESSION_KEY = (random chars -l 16)
$env.ATUIN_SESSION = (atuin uuid)
EOF
      cat << 'EOF' > "$HOME/.config/nushell/termuxify_config.nu"
$env.config = { show_banner: false }
source ~/.config/nushell/starship.nu
nerdfetch
EOF
      starship init nu | sed 's/--right//g' > "$HOME/.config/nushell/starship.nu"
      
      if ! grep -q "termuxify_env.nu" "$HOME/.config/nushell/env.nu" 2>/dev/null; then
          echo "source ~/.config/nushell/termuxify_env.nu" >> "$HOME/.config/nushell/env.nu"
      fi
      if ! grep -q "termuxify_config.nu" "$HOME/.config/nushell/config.nu" 2>/dev/null; then
          echo "source ~/.config/nushell/termuxify_config.nu" >> "$HOME/.config/nushell/config.nu"
      fi
      update_config "$HOME/.bashrc" "if [[ \$- == *i* ]] && [ -z \"$NU_VERSION\" ]; then exec nu; fi"
      chsh -s nu || true
      ;;
    "Bash")
      update_config "$HOME/.bashrc" "eval \"\$(starship init bash)\"\neval \"\$(atuin init bash)\"\nnerdfetch"
      chsh -s bash || true
      ;;
    "Zsh")
      call_gum spin --spinner dot --title "Installing Zsh..." -- pkg install -y zsh
      update_config "$HOME/.zshrc" "eval \"\$(starship init zsh)\"\neval \"\$(atuin init zsh)\"\nnerdfetch"
      update_config "$HOME/.bashrc" "if [[ \$- == *i* ]] && [ -z \"$ZSH_VERSION\" ]; then exec zsh; fi"
      chsh -s zsh || true
      ;;
    "Fish")
      call_gum spin --spinner dot --title "Installing Fish..." -- pkg install -y fish
      mkdir -p "$HOME/.config/fish"
      update_config "$HOME/.config/fish/config.fish" "starship init fish | source\natuin init fish | source\nnerdfetch"
      update_config "$HOME/.bashrc" "if [[ \$- == *i* ]] && [ -z \"$FISH_VERSION\" ]; then exec fish; fi"
      chsh -s fish || true
      ;;
  esac

  call_gum format "### [+] Default shell changed successfully to $NEW_SHELL!"
  call_gum format "### [!] Restart Termux to apply changes."
fi
