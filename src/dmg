#!/usr/bin/env bash

set -e

BACKUP_DIR="$HOME/.termuxify_backup"

call_gum() {
    if command -v gum >/dev/null 2>&1; then
        command gum "$@"
    else
        return 1
    fi
}

echo -e "\e[1;34m[*] Termuxify Uninstaller\e[0m"

if [ ! -d "$BACKUP_DIR" ]; then
    echo -e "\e[1;31m[-] Error: Backup directory $BACKUP_DIR not found.\e[0m"
    echo -e "\e[1;33m[!] Cannot safely restore original configurations. Aborting.\e[0m"
    exit 1
fi

if command -v gum >/dev/null 2>&1; then
    if ! call_gum confirm "Are you sure you want to completely restore and remove Termuxify?"; then
        echo -e "\e[1;33m[!] Restore aborted.\e[0m"
        exit 0
    fi
else
    read -p "Are you sure you want to completely restore and remove Termuxify? [y/N]: " confirm_choice
    if [[ ! "$confirm_choice" =~ ^[Yy]$ ]]; then
        echo -e "\e[1;33m[!] Restore aborted.\e[0m"
        exit 0
    fi
fi

echo -e "\e[1;34m[*] Reverting configurations...\e[0m"

# Restore files/directories from backup
restore_item() {
    local item_path="$1"
    local src="$BACKUP_DIR/$(basename "$item_path")"
    local dest="$HOME/$item_path"

    # For nested items like .config/nushell, we need to handle the structure
    if [[ "$item_path" == */* ]]; then
        src="$BACKUP_DIR/$(echo "$item_path" | sed 's/\//_/g')"
    fi

    if [ -e "$src" ]; then
        rm -rf "$dest"
        # Ensure parent directory exists
        mkdir -p "$(dirname "$dest")"
        cp -r "$src" "$dest"
        echo -e "  \e[1;32m[+]\e[0m Restored: $item_path"
    else
        # If it's a known Termuxify file, remove it
        if [ -e "$dest" ]; then
            rm -rf "$dest"
            echo -e "  \e[1;33m[-]\e[0m Removed (no backup): $item_path"
        fi
    fi
}

# Update backup logic in setup.sh to match this flattening if needed, 
# but for now let's fix the restore to be aware of how setup.sh currently backs up.
# Currently setup.sh does: cp -r "$cfg" "$BACKUP_DIR/"
# This means ~/.config/nushell becomes $BACKUP_DIR/nushell

restore_simple() {
    local name="$1"
    local dest_path="$2"
    local src="$BACKUP_DIR/$name"
    
    if [ -e "$src" ]; then
        rm -rf "$dest_path"
        mkdir -p "$(dirname "$dest_path")"
        cp -r "$src" "$dest_path"
        echo -e "  \e[1;32m[+]\e[0m Restored: $dest_path"
    else
        rm -rf "$dest_path"
        echo -e "  \e[1;33m[-]\e[0m Removed: $dest_path"
    fi
}

restore_simple ".bashrc" "$HOME/.bashrc"
restore_simple ".termux" "$HOME/.termux"
restore_simple ".zshrc" "$HOME/.zshrc"
restore_simple "nushell" "$HOME/.config/nushell"
restore_simple "fish" "$HOME/.config/fish"
restore_simple "starship.toml" "$HOME/.config/starship.toml"

# Cleanup markers in .bashrc if it was not fully restored
if [ -f "$HOME/.bashrc" ]; then
    sed -i '/# --- TERMUXIFY START ---/,/# --- TERMUXIFY END ---/d' "$HOME/.bashrc"
fi

# Cleanup artifacts
rm -rf "$HOME/.cache/starship" "$BACKUP_DIR"

echo -e "\e[1;34m[*] Removing binaries...\e[0m"
for bin in ty tt ah tc dmg nerdfetch; do
    rm -f "${PREFIX}/bin/$bin"
done

echo -e "\e[1;32m[+] Restoration complete. Please restart Termux.\e[0m"
