#!/usr/bin/env bash

set -e

BACKUP_DIR=$(ls -td "$HOME"/.termuxify_backup* 2>/dev/null | head -n 1)

call_gum() {
    if command -v gum >/dev/null 2>&1; then
        command gum "$@"
    else
        return 1
    fi
}

echo -e "\e[1;34m[*] Termuxify Uninstaller\e[0m"

if [ -z "$BACKUP_DIR" ] || [ ! -d "$BACKUP_DIR" ]; then
    echo -e "\e[1;31m[-] Error: No Termuxify backup directory found in $HOME.\e[0m"
    echo -e "\e[1;33m[!] Cannot safely restore original configurations. Aborting.\e[0m"
    exit 1
fi

echo -e "\e[1;33m[*] Using backup found at: $BACKUP_DIR\e[0m"

if command -v gum >/dev/null 2>&1; then
    if ! call_gum confirm "Are you sure you want to completely restore and remove Termuxify?"; then
        echo -e "\e[1;33m[!] Restore aborted.\e[0m"
        exit 0
    fi
else
    read -p "Are you sure you want to completely restore and remove Termuxify? [y/N]: " confirm_choice
    if [[ ! "$confirm_choice" =~ ^[Yy]$ ]]; then
        echo -e "\e[1;33m[!] Restore aborted.\e[0m"
        exit 0
    fi
fi

echo -e "\e[1;34m[*] Reverting configurations...\e[0m"

restore_simple() {
    local name="$1"
    local dest_path="$2"
    local src="$BACKUP_DIR/$name"
    
    if [ -e "$src" ]; then
        if [ -e "$dest_path" ]; then
            mv "$dest_path" "${dest_path}.bak_uninstall"
        fi
        
        mkdir -p "$(dirname "$dest_path")"
        if cp -r "$src" "$dest_path"; then
            rm -rf "${dest_path}.bak_uninstall"
            echo -e "  \e[1;32m[+]\e[0m Restored: $dest_path"
        else
            echo -e "  \e[1;31m[-] Error: Failed to restore $dest_path from backup.\e[0m"
            if [ -e "${dest_path}.bak_uninstall" ]; then
                mv "${dest_path}.bak_uninstall" "$dest_path"
                echo -e "  \e[1;33m[!]\e[0m Reverted to current version of $dest_path."
            fi
        fi
    else
        if [ -e "$dest_path" ]; then
            local should_remove=false
            if [[ "$name" == "nushell" || "$name" == "fish" || "$name" == "starship.toml" ]]; then
                should_remove=true
            elif [ -f "$dest_path" ] && grep -q "TERMUXIFY" "$dest_path"; then
                should_remove=true
            fi

            if [ "$should_remove" = true ]; then
                rm -rf "$dest_path"
                echo -e "  \e[1;33m[-]\e[0m Removed Termuxify artifact (no backup found): $dest_path"
            else
                echo -e "  \e[1;33m[?]\e[0m Keeping existing $dest_path (no backup and no Termuxify markers found)."
            fi
        fi
    fi
}

restore_simple ".bashrc" "$HOME/.bashrc"
restore_simple ".termux" "$HOME/.termux"
restore_simple ".zshrc" "$HOME/.zshrc"
restore_simple "nushell" "$HOME/.config/nushell"
restore_simple "fish" "$HOME/.config/fish"
restore_simple "starship.toml" "$HOME/.config/starship.toml"

if [ -f "$HOME/.bashrc" ]; then
    sed -i '/# --- TERMUXIFY START ---/,/# --- TERMUXIFY END ---/d' "$HOME/.bashrc"
fi

rm -rf "$HOME/.cache/starship" "$BACKUP_DIR"

echo -e "\e[1;34m[*] Removing binaries...\e[0m"
for bin in ty tt ah tc dmg mc nerdfetch; do
    rm -f "${PREFIX}/bin/$bin"
done

echo -e "\e[1;32m[+] Restoration complete. Please restart Termux.\e[0m"
