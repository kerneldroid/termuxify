#!/usr/bin/env bash

set -e

echo -e "\e[1;34m[*] Running TermuxTest (tt)...\e[0m"

echo -e "\n\e[1;33m[1] Testing Root Access & Manager...\e[0m"
if su -c 'id' >/dev/null 2>&1; then
    echo -e "\e[1;32m[+] Root access granted.\e[0m"
    if su -c 'su -v | grep -i magisk' >/dev/null 2>&1; then
        echo -e "\e[1;32m[+] Root Manager: Magisk detected.\e[0m"
    elif su -c 'ls -d /data/adb/ksu' >/dev/null 2>&1 || su -c 'which ksu' >/dev/null 2>&1; then
        echo -e "\e[1;32m[+] Root Manager: KernelSU detected.\e[0m"
    elif su -c 'ls -d /data/adb/ap' >/dev/null 2>&1 || su -c 'ls -d /data/adb/apatch' >/dev/null 2>&1; then
        echo -e "\e[1;32m[+] Root Manager: APatch detected.\e[0m"
    else
        echo -e "\e[1;32m[+] Root Manager: Unknown (SuperSU/LineageSU).\e[0m"
    fi
else
    echo -e "\e[1;31m[-] No Root access available.\e[0m"
fi

echo -e "\n\e[1;33m[2] Testing Nightzuku / Shizuku API & Connectors...\e[0m"

echo -e "[*] Querying Nightzuku Connector API..."
NIGHT_OUT=$(content query --uri content://kerneldroid.nightzuku.connector 2>/dev/null || true)
SHI_OUT=$(content query --uri content://moe.shizuku.privileged.api.connector 2>/dev/null || true)

PROVIDER_SUCCESS=false
STARTUP_CMD=""

if echo "$NIGHT_OUT" | grep -q "command="; then
    STARTUP_CMD=$(echo "$NIGHT_OUT" | grep -o 'command=.*' | cut -d= -f2-)
    echo -e "\e[1;32m[+] Nightzuku Connector is ACTIVE! Retrieved startup command.\e[0m"
    echo -e "\e[1;32m[+] Command: $STARTUP_CMD\e[0m"
    PROVIDER_SUCCESS=true
elif echo "$SHI_OUT" | grep -q "command="; then
    STARTUP_CMD=$(echo "$SHI_OUT" | grep -o 'command=.*' | cut -d= -f2-)
    echo -e "\e[1;32m[+] Shizuku Connector is ACTIVE! Retrieved startup command.\e[0m"
    echo -e "\e[1;32m[+] Command: $STARTUP_CMD\e[0m"
    PROVIDER_SUCCESS=true
else
    echo -e "\e[1;31m[-] Connectors are not active or Nightzuku/Shizuku is not installed.\e[0m"
    echo -e "\e[1;33m[!] Action: Enable \"Shizuku/Nightzuku Connectors\" in Lab Features settings.\e[0m"
fi

echo -e "[*] Testing ServiceManager Binder connection..."
if /system/bin/cmd shizuku info >/dev/null 2>&1 || cmd shizuku info >/dev/null 2>&1; then
    echo -e "\e[1;32m[+] Shizuku/Nightzuku binder service is active in ServiceManager.\e[0m"
    
    RISH_BIN=$(command -v rish 2>/dev/null || true)
    if [ -n "$RISH_BIN" ]; then
        echo -e "\e[1;32m[+] Found rish client at: $RISH_BIN\e[0m"
        echo -e "[*] Testing active execution permissions through Shizuku binder..."
        
        if RISH_EXEC=$(timeout 3 rish -c "id" 2>/dev/null); then
            if echo "$RISH_EXEC" | grep -E 'uid=2000|uid=0' >/dev/null; then
                echo -e "\e[1;32m[+] SUCCESS: Shizuku binder is fully authorized for Termux!\e[0m"
                echo -e "\e[1;32m[+] Execution Context: $RISH_EXEC\e[0m"
                
                echo -e "[*] Running complex diagnostics through Shizuku..."
                DEVICE_MODEL=$(rish -c "getprop ro.product.model" 2>/dev/null || echo "Unknown")
                OS_VER=$(rish -c "getprop ro.build.version.release" 2>/dev/null || echo "Unknown")
                SYS_UPTIME=$(rish -c "uptime" 2>/dev/null || echo "Unknown")
                echo -e "\e[1;32m[+] Device: $DEVICE_MODEL | OS: Android $OS_VER | Uptime: $SYS_UPTIME\e[0m"
                
                echo -e "[*] Checking installed ADB Modules..."
                NIGHT_MODS=$(rish -c "ls -la /data/user/0/kerneldroid.nightzuku/files/adb_modules/ 2>/dev/null | grep -v '^total'" 2>/dev/null || true)
                SHI_MODS=$(rish -c "ls -la /data/user/0/moe.shizuku.privileged.api/files/adb_modules/ 2>/dev/null | grep -v '^total'" 2>/dev/null || true)
                
                if [ -n "$NIGHT_MODS" ]; then
                    echo -e "\e[1;32m[+] Installed Nightzuku ADB Modules:\e[0m"
                    echo "$NIGHT_MODS" | awk '{print "  - " $NF}'
                elif [ -n "$SHI_MODS" ]; then
                    echo -e "\e[1;32m[+] Installed Shizuku ADB Modules:\e[0m"
                    echo "$SHI_MODS" | awk '{print "  - " $NF}'
                else
                    echo -e "\e[1;33m[-] No ADB Modules found.\e[0m"
                fi
            else
                echo -e "\e[1;31m[-] ERROR: rish executed but returned unexpected UID context: $RISH_EXEC\e[0m"
            fi
        else
            echo -e "\e[1;31m[-] ERROR: Shizuku execution test failed or timed out. Termux is NOT authorized!\e[0m"
            echo -e "\e[1;33m[!] Action: Open the Shizuku/Nightzuku app, go to \"Authorized apps\" and toggle Termux ON.\e[0m"
        fi
    else
        echo -e "\e[1;31m[-] ERROR: rish connector not found in PATH.\e[0m"
        echo -e "\e[1;33m[!] Tip: Copy rish files from the Shizuku app (use \"Export files\" in the Shizuku app) to your Termux bin directory.\e[0m"
    fi
else
    echo -e "\e[1;31m[-] ERROR: Shizuku binder service is NOT active in the system.\e[0m"
    echo -e "\e[1;33m[!] Action: Open Shizuku/Nightzuku app and start it via Wireless Debugging or Root.\e[0m"
fi

echo -e "\n\e[1;32m[+] Testing complete.\e[0m"
