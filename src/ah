#!/usr/bin/env bash

set -e

if ! command -v gum >/dev/null 2>&1; then
    echo -e "\e[1;31m[-] Error: Required dependency 'gum' is not installed.\e[0m"
    echo -e "\e[1;33m[!] Please run setup.sh first.\e[0m"
    exit 1
fi

declare -a ALIASES

# Improved parsing function
parse_aliases() {
    local file="$1"
    local shell_type="$2"
    local pattern
    
    if [ ! -f "$file" ]; then return; fi

    if [ "$shell_type" == "Bash" ]; then
        # Matches: alias name='command' or alias name="command"
        pattern="^alias[[:space:]]+([^=]+)=['\"](.+)['\"]$"
    else
        # Matches: alias name = command
        pattern="^alias[[:space:]]+([^[:space:]]+)[[:space:]]*=[[:space:]]*(.+)$"
    fi

    while IFS= read -r line; do
        if [[ $line =~ $pattern ]]; then
            name="${BASH_REMATCH[1]}"
            cmd="${BASH_REMATCH[2]}"
            # Escape commas for CSV-like structure
            name="${name//,/\\,}"
            cmd="${cmd//,/\\,}"
            ALIASES+=("$name,$cmd,$shell_type")
        fi
    done < "$file"
}

parse_aliases "$HOME/.bashrc" "Bash"
parse_aliases "$HOME/.config/nushell/config.nu" "Nushell"

echo -e "\e[1;34m[*] Termuxify: Active Aliases Manager\e[0m"

if [ ${#ALIASES[@]} -eq 0 ]; then
    echo -e "\e[1;33m[!] No aliases found.\e[0m"
    exit 0
fi

# Prepare data for gum table
TABLE_DATA="Alias,Command,Shell\n"
for entry in "${ALIASES[@]}"; do
    TABLE_DATA+="$entry\n"
done

# Use TAB as separator for gum table to avoid comma issues in commands
echo -e "$TABLE_DATA" | sed 's/,/	/g' | gum table --border rounded --header.foreground 212 --cell.foreground 99
