#!/usr/bin/env bash

set -e

if ! command -v gum >/dev/null 2>&1; then
    echo -e "\e[1;31m[-] Error: Required dependency 'gum' is not installed.\e[0m"
    echo -e "\e[1;33m[!] Please run setup.sh first.\e[0m"
    exit 1
fi

BASH_RC="$HOME/.bashrc"
NU_CONFIG="$HOME/.config/nushell/config.nu"

# Function to update Nushell config
update_nu_alias() {
    local name="$1"
    local cmd="$2"
    local action="$3" # "add" or "remove"

    [ ! -d "$(dirname "$NU_CONFIG")" ] && mkdir -p "$(dirname "$NU_CONFIG")"
    [ ! -f "$NU_CONFIG" ] && touch "$NU_CONFIG"

    # Remove existing alias to prevent duplicates
    # Use | as sed delimiter to handle potential / in name
    sed -i "\|^alias $name =|d" "$NU_CONFIG"

    if [[ "$action" == "add" ]]; then
        # Nushell aliases are best quoted
        echo "alias $name = \"$cmd\"" >> "$NU_CONFIG"
    fi
}

# Function to update Bash config
update_bash_alias() {
    local name="$1"
    local cmd="$2"
    local action="$3" # "add" or "remove"

    [ ! -f "$BASH_RC" ] && touch "$BASH_RC"

    # Remove existing alias to prevent duplicates
    sed -i "\|^alias $name=|d" "$BASH_RC"

    if [[ "$action" == "add" ]]; then
        # Escape single quotes for Bash: replace ' with '\''
        local escaped_cmd="${cmd//\'/\'\\\'\'}"
        echo "alias $name='$escaped_cmd'" >> "$BASH_RC"
    fi
}

get_aliases() {
    ALIASES=()
    # Bash aliases
    if [ -f "$BASH_RC" ]; then
        while IFS= read -r line; do
            # Match alias name=value (value can be quoted or not)
            if [[ "$line" =~ ^alias[[:space:]]+([^=]+)=\'?(.*)\'?$ ]]; then
                local name="${BASH_REMATCH[1]}"
                local cmd="${BASH_REMATCH[2]}"
                # Strip trailing quote if it exists (the regex above might leave it if it started with one)
                cmd="${cmd%\'}"
                ALIASES+=("$name	$cmd	Bash")
            fi
        done < "$BASH_RC"
    fi
    # Nushell aliases
    if [ -f "$NU_CONFIG" ]; then
        while IFS= read -r line; do
            # Match alias name = value
            if [[ "$line" =~ ^alias[[:space:]]+([^[:space:]]+)[[:space:]]*=[[:space:]]*\"?(.*)\"?$ ]]; then
                local name="${BASH_REMATCH[1]}"
                local cmd="${BASH_REMATCH[2]}"
                cmd="${cmd%\"}"
                ALIASES+=("$name	$cmd	Nushell")
            fi
        done < "$NU_CONFIG"
    fi
}

while true; do
    ACTION=$(gum choose "List Aliases" "Add Alias" "Remove Alias" "Exit" --header "Alias Manager")

    case "$ACTION" in
        "List Aliases")
            get_aliases
            if [ ${#ALIASES[@]} -eq 0 ]; then
                gum format "### No aliases found."
            else
                echo -e "Alias	Command	Shell" > /tmp/aliases.tsv
                for a in "${ALIASES[@]}"; do echo -e "$a" >> /tmp/aliases.tsv; done
                gum table < /tmp/aliases.tsv --border rounded --header.foreground 212
                rm /tmp/aliases.tsv
            fi
            ;;
        "Add Alias")
            NAME=$(gum input --placeholder "Alias name (e.g. g)")
            [ -z "$NAME" ] && continue
            COMMAND=$(gum input --placeholder "Command (e.g. git status)")
            [ -z "$COMMAND" ] && continue
            SHELL_TYPE=$(gum choose "Bash" "Nushell" "Both")
            
            if [[ "$SHELL_TYPE" == "Bash" || "$SHELL_TYPE" == "Both" ]]; then
                update_bash_alias "$NAME" "$COMMAND" "add"
            fi
            if [[ "$SHELL_TYPE" == "Nushell" || "$SHELL_TYPE" == "Both" ]]; then
                update_nu_alias "$NAME" "$COMMAND" "add"
            fi
            gum format "### [+] Alias '$NAME' added successfully."
            ;;
        "Remove Alias")
            get_aliases
            if [ ${#ALIASES[@]} -eq 0 ]; then
                gum format "### No aliases to remove."
                continue
            fi
            TO_REMOVE=$(printf "%s\n" "${ALIASES[@]}" | gum choose --header "Select alias to remove:")
            [ -z "$TO_REMOVE" ] && continue
            
            NAME=$(echo "$TO_REMOVE" | cut -f1)
            STYPE=$(echo "$TO_REMOVE" | cut -f3)
            
            if [ "$STYPE" == "Bash" ]; then
                update_bash_alias "$NAME" "" "remove"
            else
                update_nu_alias "$NAME" "" "remove"
            fi
            gum format "### [-] Alias '$NAME' removed from $STYPE."
            ;;
        "Exit")
            break
            ;;
    esac
done
